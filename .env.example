NEXT_PUBLIC_WS_URL=ws://localhost:8080
WS_PORT=8080
NODE_ENV=development

# Sandbox execution bridge. Defaults are safe: no real-money trading.
# DRY_RUN plans signed payloads but does not submit. TEST_ORDER validates Binance
# order payloads via /api/v3/order/test. LIVE_SANDBOX submits to Binance Spot
# Testnet and OKX Demo Trading only.
SANDBOX_ORDER_MODE=DRY_RUN
SANDBOX_MAX_NOTIONAL_USD=25
BINANCE_TESTNET_API_KEY=
BINANCE_TESTNET_API_SECRET=
OKX_DEMO_API_KEY=
OKX_DEMO_API_SECRET=
OKX_DEMO_API_PASSPHRASE=
